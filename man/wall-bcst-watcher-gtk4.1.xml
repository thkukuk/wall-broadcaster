  <refnamediv>
    <refname>wall-bcst-watcher-gtk4</refname>
    <refpurpose>listen on wall broadcast messages</refpurpose>
  </refnamediv>
  <refsynopsisdiv>
    <cmdsynopsis>
      <command>wall-bcst-watcher-gtk4</command>
      <arg choice="opt"><option>--help</option></arg>
      <arg choice="opt"><option>--version</option></arg>
    </cmdsynopsis>
  </refsynopsisdiv>
  <refsect1>
    <title>DESCRIPTION</title>
    <para>A GTK4 application, which listens to org.opensuse.WallBroadcast messages and opens a popup window for each message.</para>
  </refsect1>
  <refsect1>
    <title>OPTIONS</title>
    <variablelist>
      <varlistentry>
        <term><option>-h</option>, <option>--help</option></term>
        <listitem>
          <para>Give this help list</para>
        </listitem>
      </varlistentry>
      <varlistentry>
        <term><option>-v</option>, <option>--version</option></term>
        <listitem>
          <para>Print program version</para>
        </listitem>
      </varlistentry>
    </variablelist>
  </refsect1>

