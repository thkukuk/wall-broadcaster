  <refnamediv>
    <refname>wall-bcst-gateway</refname>
    <refpurpose>forward wall broadcast messages as notification</refpurpose>
  </refnamediv>

  <refsynopsisdiv>
    <cmdsynopsis>
      <command>wall-bcst-gateway</command>
      <arg choice="opt"><option>-d</option></arg>
      <arg choice="opt"><option>--help</option></arg>
      <arg choice="opt"><option>--version</option></arg>
    </cmdsynopsis>
  </refsynopsisdiv>
  <refsect1>
    <title>DESCRIPTION</title>
    <para>This application will register to the system dbus and the user session dbus of the Desktop Environment and convert messages coming from org.opensuse.WallBroadcast to Freedesktop notifications. It should be started by the user at login time.</para>
  </refsect1>
  <refsect1>
    <title>OPTIONS</title>
    <variablelist>
      <varlistentry>
        <term><option>-d</option>, <option>--debug</option></term>
        <listitem>
          <para>Print debug messages</para>
        </listitem>
      </varlistentry>
      <varlistentry>
        <term><option>-h</option>, <option>--help</option></term>
        <listitem>
          <para>Give this help list</para>
        </listitem>
      </varlistentry>
      <varlistentry>
        <term><option>-v</option>, <option>--version</option></term>
        <listitem>
          <para>Print program version</para>
        </listitem>
      </varlistentry>
    </variablelist>
  </refsect1>

